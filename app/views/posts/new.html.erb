<div class="post-form-container">
  <h1 class="headline">新規投稿</h1>

  <div class="form-card">
    <%= form_with model: @post, local: true do |f| %>
   <%# 【修正】画像選択（複数選択できるように変更！） %>
      <div class="form-group">
        <%# :image から :images に変更 %>
        <%= f.label :images, "画像を選択（複数選択可）", class: "form-label" %>
        <div class="file-input-wrapper">
          <%# :image から :images に変更し、multiple: true を追加！ %>
          <%= f.file_field :images, multiple: true, class: "file-input" %>
        </div>
      </div>

      <%# タイトル %>
      <div class="form-group">
        <%= f.label :title, "タイトル", class: "form-label" %>
        <%= f.text_field :title, required: true, class: "text-input", placeholder: "タイトルの入力（必須）" %>
      </div>

      <%# 本文 %>
      <div class="form-group">
        <%= f.label :body, "本文", class: "form-label" %>
        <%= f.text_area :body, rows: 8, class: "textarea-input", placeholder: "ここに内容を入力してください..." %>
      </div>

      <%# ボタンエリア %>
      <div class="form-actions">
        <%= f.submit "投稿を公開する", class: "btn btn-primary" %>
        <%= link_to "キャンセル", posts_path, class: "btn btn-outline" %>
      </div>
      
    <% end %>
  </div>
</div>