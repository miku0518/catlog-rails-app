<div class="container">
  <div class="top-card">
    <span class="badge">～猫好きのコミュニティへようこそ～</span>
    <p class="text">
      キャットlogは猫好きのための掲示板アプリです。<br />
      あなたの愛猫のかわいい瞬間や、悩みを共有しましょう。
    </p>
  </div>
</div>

<p class="headline">最新の投稿</p>

<%# 1. index-post-list クラスを追加してCSSを共通化します %>
<div class="post-list index-post-list">
  <% @posts.each do |post| %>
    <%# 2. post-card クラスを追加します %>
    <div class="card">
      
      <%# --- 画像エリア --- %>
      <div class="post-image-wrapper">
        <% if post.image.attached? %>
          <%= image_tag post.image, class: "post-image", alt: post.title %>
        <% else %>
          <%= image_tag "no_image.png", class: "post-image", alt: "No image" %>
        <% end %>
      </div>

      <%# --- コンテンツエリア --- %>
       <div class="post-card">
        <div class="card-title">
          <%= link_to truncate(post.title, length: 15, omission: '...'), post_path(post), class: "hover:text-blue-500" %>
        </div>
        
        <p class="text-sm text-gray-500">投稿者：<%= post.user.login_name %></p>

        <%# --- アイコン（コメント・いいね）エリア --- %>
        <%# ここはCSSで右寄せ（justify-content: flex-end）になります %>
        <div class="post-meta-area">
          <div class="comment-status">
            <span class="material-symbols-outlined icon-small">chat_bubble</span>
            <%# style ではなく class="count-text" に修正しました %>
            <span class="count-text"><%= post.comments.count %></span>
          </div>

          <%# いいねボタン部品 %>
          <%= render "likes/like_button", post: post %>
        </div>

        <%# --- 日付と詳細ボタン --- %>
        <p class="post-date">
          <%= post.created_at.strftime("%Y/%-m/%-d %-H:%M") %>
        </p>
        
        <%# flex justify-end を残しておけば、ボタンも右に寄ります %>
        <div class="post-actions">
          <%= link_to "続きを読む", post_path(post), class: "btn btn-outline btn-info btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="pagination-wrapper">
  <%= paginate @posts %>
</div>